{
  "name": "cypress",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:frontend": "cypress run --spec 'cypress/e2e/frontend/**/*.cy.js'",
    "cy:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.js'",
    "cy:report": "cypress run",
    "cy:smoke": "cypress run --env grepTags=@smoke",
    "cy:critical": "cypress run --env grepTags=@critical",
    "cy:regression": "cypress run --env grepTags=@regression"
  },
